<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="shortcut icon" href="./favicon.ico" type="favicon">
  <link rel="icon" href="./favicon.ico" type="image/x-icon">
  <title>Contact Sales — Nexora</title>
  <link rel="stylesheet" href="mystyle.css">
  <script src="include-html.js"></script>
</head>
<body>
  <nav include-html="./navbar.html"></nav>
  <script>includeHTML();</script>

  <section class="hero" style="padding: 80px 0;">
    <div class="container" style="max-width: 640px;">
      <p class="eyebrow">Let's Talk</p>
      <h1>Ready to <span class="grad">10x</span> your organization?</h1>
      <p class="lede">
        Our enterprise concierge team typically responds within 4 business quarters. Fill out the form
        below and one of our solutions architects will reach out from a no-reply@ address.
      </p>

      <form class="contact-form" onsubmit="event.preventDefault(); document.getElementById('thanks').style.display='block'; this.style.display='none';">
        <label>Full Name <input type="text" required placeholder="Jaxon Reeves III"></label>
        <label>Work Email <input type="email" required placeholder="founder@yourstartup.io"></label>
        <label>Company <input type="text" required placeholder="Stealth-mode unicorn"></label>
        <label>Annual Revenue
          <select>
            <option>$0 — pre-revenue (we love this)</option>
            <option>$1M — $10M ARR</option>
            <option>$10M — $100M ARR</option>
            <option>$100M+ (please reach out personally)</option>
          </select>
        </label>
        <label>Astrological Sign (for compatibility scoring)
          <select>
            <option>Aries — Disruptor</option>
            <option>Taurus — Operator</option>
            <option>Gemini — Visionary</option>
            <option>Other / Skeptic</option>
          </select>
        </label>
        <label>How urgent is your need?
          <select>
            <option>Yesterday</option>
            <option>This sprint</option>
            <option>Q3 2026</option>
            <option>Just kicking tires</option>
          </select>
        </label>
        <button type="submit" class="cta-primary" style="border:0;">Submit & Begin Discovery →</button>
        <p class="fineprint">By submitting, you consent to a 12-month nurture sequence and at least three follow-ups from someone named Connor.</p>
      </form>

      <div id="thanks" style="display:none; text-align:center; padding: 40px 20px;">
        <h2>✨ Thanks! Your request has been queued. ✨</h2>
        <p style="color: var(--muted);">A solutions architect will reach out within 4–8 business quarters. In the meantime, follow us on X for thought leadership.</p>
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p class="copyright" style="text-align: center;">© 2026 Nexora Labs Inc.</p>
    </div>
  </footer>
</body>
</html>
